#!/bin/sh
# Thin wrapper: delegates to the stoandl fat JAR in ctl mode.
#
# No --add-opens flags here: those exist only for the daemon's BecomeMonitor reflection
# (DbusNotificationMonitor). CLI subcommands just make plain D-Bus client calls, and on the
# classpath dbus-java is in the unnamed module anyway — passing them only produced
# "WARNING: Unknown module: org.freedesktop.dbus specified to --add-opens".
exec java -jar /usr/lib/stoandl/stoandl.jar ctl "$@"
