# stoandl configuration
#
# Copy to ~/.config/stoandl/stoandl.conf (or $XDG_CONFIG_HOME/stoandl/stoandl.conf)
# and restart the service:  systemctl --user restart stoandl
#
# Syntax: `key = value`, `#` starts a comment. List values are comma-separated.

# Per-app mute store. When on, every desktop app that notifies is tracked and its mute state is
# enforced host-side before sending (the notification is dropped before it crosses BLE). Manage it at
# runtime with `stoandl notif` (list / mute <app> [always|weekdays|weekends|1h|2d] / unmute /
# mute-all / style), or with the "Mute" action on a notification on the watch. On by default.
notification.per_app = true
# Mute state applied to a newly observed app: never (deliver), always (mute), weekdays, or weekends.
notification.default_mute = never
# Sync the per-app list + mute states to the watch (libpebble3 NotificationAppItem -> BlobDB).
# OFF by default: current Core/PebbleOS firmware has no per-app notification UI on the watch
# (Settings->Notifications is global-only), so the synced records surface nowhere — mute is
# enforced host-side regardless. Opt-in for firmware that does surface it. BLE-only, no web egress.
notification.sync_to_watch = false

# Telephony/dialer apps. Their notifications are suppressed from the watch (the native call
# screen replaces them), and their notification title is used as a fallback caller name when
# the number isn't found in the vCard files below.
# Defaults to "spacebar, calls" (Plasma Mobile Spacebar + GNOME Calls) if unset.
call.dialer_apps = spacebar, calls

# vCard (.vcf) files or directories scanned for caller-ID resolution. Numbers are matched
# digits-only by suffix, so +49… and local 0… forms both resolve. `~` expands to your home.
# Plasma Mobile's kpeoplevcard backend stores contacts here by default:
contacts.vcard_paths = ~/.local/share/kpeoplevcard

# Weather, pushed to the watch's built-in Weather app. Source is Open-Meteo (free, no API key,
# no account). There's no GPS on a headless daemon, so list fixed locations as Name:lat:lon.
# Leave empty to disable. The first location is shown most prominently on the watch.
# Example: weather.locations = Berlin:52.52:13.405, London:51.5074:-0.1278
weather.locations =

# Optionally import extra locations from your desktop instead of typing coordinates. No DE shares its
# weather data, but the chosen place is readable:
#   manual  - only weather.locations above (default)
#   gnome   - read GNOME/Phosh weather GSettings (org.gnome.shell.weather / org.gnome.Weather)
#   command - run weather.location_command, which must print Name:lat:lon lines (DE-agnostic)
# Imported locations are merged with weather.locations and re-read on every refresh.
weather.location_source = manual
# weather.location_command = echo "Munich:48.137:11.575"
#
# KDE/Plasma has no coordinate store, so resolve a city name to coordinates via Open-Meteo's free
# geocoder (needs curl + jq); swap Munich for your city (or splice it from KWeather's config):
# weather.location_command = curl -s "https://geocoding-api.open-meteo.com/v1/search?name=Munich&count=1" | jq -r '.results[0] | "\(.name):\(.latitude):\(.longitude)"'

# Temperature unit sent to the watch: metric (°C) or imperial (°F).
weather.units = metric

# Minutes between weather refreshes (also refreshes immediately when a watch connects).
weather.interval = 30

# Advanced watch settings (the ones the official app exposes but the watch menus don't): quick-launch
# button mappings, ambient-light threshold, backlight, vibration, etc. Run `stoandl settings` to see every
# available id, its current value and allowed values. Set them as `watch.<id> = <value>`; they're
# re-applied on every connect (config wins over on-watch changes). Examples:
# watch.lightAmbientThreshold = 200
# watch.clock24h = true
# watch.qlUp = Music          # hold Up quick-launches Music (app name or UUID; "off" to clear)
# watch.textStyle = Larger

# Optional GPS: add a "current location" entry tracked via GeoClue2 (modem GPS / Wi-Fi / A-GPS).
# It's shown first on the watch and re-resolved every refresh. The place name is reverse-geocoded
# from the coordinates (OSM Nominatim), falling back to weather.gps_name.
# GeoClue must allow this daemon — add to /etc/geoclue/geoclue.conf (id matches weather.gps_desktop_id):
#   [stoandl]
#   allowed=true
#   system=true
#   users=
weather.gps = false
weather.gps_desktop_id = stoandl
weather.gps_name = Current location

# Reverse-geocode the GPS coordinates to a place name via OSM Nominatim. Off by default: it sends
# your coordinates to a third-party web service. When off, the GPS entry uses weather.gps_name.
weather.reverse_geocode = false

# Weather timeline pins: a sunrise + sunset pin per day (today … +2 days) for the primary location
# (the GPS current location if enabled, otherwise the first weather.locations entry), with the other
# locations shown in the pin's detail view. Replicates the original Core app. On by default whenever
# weather is enabled; set to false to keep the Weather app but leave the timeline clear.
weather.pins = true

# Calendar → watch timeline. Syncs upcoming events (yesterday … +7 days) as native calendar pins.
# Disabled until you set at least one source below. Local .ics and discovery make no web requests;
# ical_urls and caldav are opt-in egress.
#
# Local .ics files or directories (scanned for *.ics). `~` expands to your home. The DE-agnostic path:
#   - Plasma Mobile (Calindori) keeps calendars as plain .ics under ~/.local/share/calindori
#   - or any .ics your calendar app writes / vdirsyncer syncs
# Example: calendar.ics_paths = ~/.local/share/calindori, ~/calendars/work.ics
calendar.ics_paths =

# Auto-discover the desktop's local .ics calendars (Calindori, ~/.calendars, ~/calendars). No egress.
calendar.discover = false

# Published iCal feed URLs — an HTTP(S) GET of an .ics (e.g. a Google/Nextcloud/Outlook "secret iCal
# address"). Opt-in egress. GNOME (Evolution Data Server) and KDE (Akonadi) *online* calendars aren't
# read natively yet — use their iCal URL here, or caldav below.
# Example: calendar.ical_urls = https://example.com/cal.ics
calendar.ical_urls =

# CalDAV, each url|username|password (Basic auth). Opt-in egress. Point at an ACCOUNT/principal URL to
# auto-discover and sync ALL the user's calendars; or a single collection URL for just that one.
# (Use `stoandl calendar disable <id>` to drop discovered calendars you don't want.)
# Credentials are stored here in plaintext — protect this file.
# Example (account): calendar.caldav = https://dav.example.com/dav/alice@example.com/|alice|s3cret
calendar.caldav =

# Minutes between calendar refreshes (also re-reads on local .ics change and `stoandl calendar sync`).
calendar.sync_interval = 30

# ── Datalog ────────────────────────────────────────────────────────────────────────────────────
# Capture data logged by custom watchapps via the PebbleKit DataLogging API. Frames are written
# append-only as NDJSON, one file per (app UUID, tag): ~/.config/stoandl/datalog/<uuid>/<tag>.ndjson.
# Inspect with `stoandl datalog list|dump|tail`. Local-only (no egress), but it writes app-supplied
# data to disk and a chatty sensor app can grow the files without bound — so it's off by default.
# Enable it to discover which of your apps actually log data.
datalog.enabled = false

# ── Firmware updates ─────────────────────────────────────────────────────────────────────────────
# Flashing a LOCAL firmware bundle always works and needs nothing here:
#     stoandl firmware /path/to/normal_<board>_<version>.pbz
# (libpebble3 validates the bundle against the connected watch — board, CRC, slot — before flashing.)
#
# The keys below only enable the OPTIONAL `stoandl firmware check` / `firmware update` commands, which
# fetch firmware over the network from a public GitHub repo's releases. Opt-in egress → off by default.
# Core devices (Pebble 2 Duo / Pebble Time 2) publish per-board `normal_<board>_<version>.pbz` bundles
# there; classic Pebbles do not (their firmware lives on cohorts.rebble.io and isn't covered here).
firmware.github = false

# owner/repo whose releases carry the .pbz bundles. Defaults to the PebbleOS source.
firmware.github_repo = coredevices/PebbleOS

# Consider GitHub pre-releases too (otherwise only the latest stable release).
firmware.github_prereleases = false

# When firmware.github is on, also push a notification TO THE WATCH when newer firmware is available
# (checked on connect and at most once a day). The notification has an "Update" button that downloads
# and flashes it. On by default once firmware.github is enabled; set false for check-on-demand only.
firmware.notify = true

# ── Developer connection ─────────────────────────────────────────────────────────────────────────
# Bridge the Pebble SDK / CloudPebble to the watch over BLE, so `pebble install --phone <this-host>`
# and live app debugging work through stoandl (what the official app's developer connection does).
# Toggle it on demand — no config needed:
#     stoandl developer start | stop | status
#
# ⚠ This opens an UNAUTHENTICATED WebSocket server on 0.0.0.0:9000 (all interfaces): while it runs,
# anyone on your network can install apps and relay protocol traffic to the watch. So it's off by
# default and you start it explicitly. Set the key below to auto-start it on every watch connect
# (e.g. a dedicated dev device) — leave it false unless you understand the exposure.
developer.autostart = false

# ── Health / activity ──────────────────────────────────────────────────────────────────────────
# Pull the watch's health data (steps, distance, calories, active minutes, sleep, heart rate, and
# Walk/Run/workout sessions) into the host. The watch only sends it when asked, so when health.sync
# is on, stoandl requests it on every connect (incremental — the first run is a full pull). The data
# lands in the shared libpebble3 DB; health.export projects it to readable NDJSON under
# ~/.config/stoandl/health/ (daily.ndjson, activities.ndjson) whenever new data arrives. Read it with
# `stoandl health [days] | activities | dump`, or `stoandl health sync` to pull on demand.
# Local-only — nothing is uploaded — so both are on by default.
health.sync = true
health.export = true

# Also export minute-level samples (steps + heart rate per minute) to health/samples/<date>.ndjson.
# Much higher volume than the daily summary, so off by default.
health.export_samples = false

# How many days back each export re-projects (the daily/activities/samples window). Older days already
# written stay in place. Default 30.
health.export_days = 30

# ── Reconnect (EXPERIMENTAL) ─────────────────────────────────────────────────────────────────────
# A bonded watch normally reconnects via BlueZ's own background auto-connect — no app scan. That is
# rock-solid for the BLE-native watches (Pebble Time 2 / Pebble 2). But a classic-era Pebble Time /
# Time Steel advertises as "Pebble Time LE XXXX" with a *rotating* Resolvable Private Address: after a
# drop the kernel's accept-list path is pinned to the now-stale dev_<oldRPA> object and can never
# re-match it, so the watch never comes back. Turning this on makes stoandl run an ACTIVE scan when a
# bonded watch has been down past a short grace (~20s) and reconnect it under its *current* object path
# — the same path the initial connect uses. It only kicks in after the grace, so the BLE-native watches
# (which reconnect in a few seconds via the kernel path) never trigger a rescan.
#
# Doubles as a diagnostic: watch the log after a drop for "Starting BLE scan (active reconnect rescan…)"
# and "BluezBleScanner: pebble match count". If the watch never appears, it isn't advertising at all
# after a disconnect — in which case NO BLE strategy can recover it and BT Classic is the only path.
reconnect.active_rescan = false
