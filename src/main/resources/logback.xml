<configuration>
    <!--
        Default: INFO — startup, connection, notifications, PKJS lifecycle only.
        Verbose: set STOANDL_LOG=DEBUG (env var or -DSTOANDL_LOG=DEBUG JVM flag).
    -->
    <property name="logLevel" value="${STOANDL_LOG:-INFO}"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/tmp/stoandl.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.FixedWindowRollingPolicy">
            <fileNamePattern>/tmp/stoandl.%i.log</fileNamePattern>
            <minIndex>1</minIndex>
            <maxIndex>3</maxIndex>
        </rollingPolicy>
        <triggeringPolicy class="ch.qos.logback.core.rolling.SizeBasedTriggeringPolicy">
            <maxFileSize>5MB</maxFileSize>
        </triggeringPolicy>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- stoandl own code: startup, scan, connect, notify — always INFO -->
    <logger name="de.yoxcu.stoandl" level="INFO"/>

    <!-- Datalog capture: per-frame detail is DEBUG — honor STOANDL_LOG so `STOANDL_LOG=DEBUG`
         surfaces each captured custom-watchapp frame (otherwise the parent pins it to INFO). -->
    <logger name="de.yoxcu.stoandl.datalog" level="${logLevel}"/>

    <!-- PKJS lifecycle events (JS bridge init, ready, webhook, status) — always INFO -->
    <logger name="PrivatePKJSInterface" level="INFO"/>
    <logger name="CompanionAppLifecycleManager" level="INFO"/>
    <logger name="PKJSApp" level="INFO"/>
    <logger name="GraalJsRunner" level="INFO"/>
    <!-- XHR: only log errors; PKJS console.log covers the normal case -->
    <logger name="JvmXHR" level="WARN"/>
    <logger name="JvmPKJS" level="INFO"/>

    <!-- BLE / connection details: per-packet spam in debug mode only -->
    <logger name="PPoG" level="${logLevel}"/>
    <logger name="BluezGattServer" level="${logLevel}"/>
    <logger name="GattServerManager" level="${logLevel}"/>
    <logger name="PebbleBle" level="${logLevel}"/>
    <logger name="PebbleConnector" level="${logLevel}"/>
    <logger name="PairingJvm" level="${logLevel}"/>
    <!-- Decoded Pebble-protocol packet traces (inbound + outbound) — DEBUG-only firehose,
         but the only way to see what the watch actually sends (e.g. timeline actions). -->
    <logger name="PebbleProtocol" level="${logLevel}"/>
    <logger name="PebbleProtocolRunner" level="${logLevel}"/>

    <!-- Watch-side blobdb write-back for pref keys libpebble3 doesn't map (DnD schedule,
         HRM prefs, etc.). Harmless — watch firmware has more pref types than we know about. -->
    <logger name="WatchPrefItem" level="WARN"/>
    <logger name="WatchPrefRealDao" level="WARN"/>

    <!-- Suppress permanently — these are never useful at normal verbosity -->
    <logger name="org.freedesktop.dbus" level="WARN"/>
    <!-- ical4j Configurator logs "ical4j.properties not found." at INFO on startup (an empty
         ical4j.properties on the classpath silences it at the source); WARN catches any other chatter. -->
    <logger name="net.fortuna.ical4j" level="WARN"/>
    <logger name="WatchManager" level="WARN"/>
    <logger name="AppOrderManager" level="WARN"/>
    <!-- Health pipeline — follows STOANDL_LOG (quiet at INFO; all the useful lines are DEBUG). At DEBUG:
         HealthDataProcessor logs each datalog frame ("handleSendDataItems …", "Parsed N step/overlay
         records", "Received sleep tag data"); HealthService logs the sync request + watermark
         ("Requesting incremental health data sync (last <N>s)"); SleepSessionGrouper logs "Found N sleep
         entries …" — the decisive signals for diagnosing empty steps/sleep/HR. -->
    <logger name="HealthDataProcessor" level="${logLevel}"/>
    <logger name="HealthService" level="${logLevel}"/>
    <logger name="SleepSessionGrouper" level="${logLevel}"/>
    <logger name="Health" level="${logLevel}"/>
    <logger name="ConnectivityWatcher" level="WARN"/>
    <!-- Follows STOANDL_LOG: at DEBUG it logs each watch insert ("insert: Weather …") and, crucially,
         "handleInsert: value is null: Weather …" when a record is dropped for a missing watch
         capability (e.g. SupportsWeatherApp) — the decisive signal for diagnosing empty weather. -->
    <logger name="BlobDB" level="${logLevel}"/>
    <!-- Calendar sync detail from libpebble3 (Got N calendars, New/Deleting Pin, Synced) — follows
         STOANDL_LOG. stoandl's own calendar reader logs a per-sync summary at INFO regardless. -->
    <logger name="PhoneCalendarSyncer" level="${logLevel}"/>
    <!-- Music control (MPRIS bridge) watch-side protocol detail — follows STOANDL_LOG.
         stoandl's MprisMusicControl logs the user-facing music activity at INFO regardless. -->
    <logger name="MusicControlManager" level="${logLevel}"/>
    <logger name="SystemService" level="WARN"/>
    <logger name="Negotiator" level="WARN"/>
    <logger name="FirmwareUpdateManager" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
